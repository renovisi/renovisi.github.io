---
const { 
    href = '', 
    class: className = '',
    target = '',  
} = Astro.props;
---

<a href={href ?? '#'} class={`rounded inline-block font-bold bg-blue-500 hover:bg-blue-600 cursor-pointer text-white px-4 py-3 text-lg sm:text-base ${className}`} target={target || undefined}>
	<slot />
</a>