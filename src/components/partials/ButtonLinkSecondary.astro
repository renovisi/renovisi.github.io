---
const { 
    href = '', 
    class: className = '',
    target = '',  
} = Astro.props;
---

<a href={href ?? '#'} class={`rounded inline-block font-bold bg-white hover:bg-neutral-200 cursor-pointer text-black px-4 py-3 text-lg sm:text-base ${className}`} target={target || undefined}>
	<slot />
</a>